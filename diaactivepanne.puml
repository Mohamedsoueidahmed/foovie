@startuml ActiviteGestionPanne
title Diagramme d'activité — Cycle de gestion d'une panne

skinparam shadowing false
skinparam ArrowColor #34495E
skinparam activity {
  BorderColor #34495E
  BackgroundColor #FBFCFC
  DiamondBorderColor #34495E
  DiamondBackgroundColor #FCF3CF
  StartColor #1E8449
  EndColor #C0392B
  BarColor #34495E
}

|#D6EAF8|Agent de service|
start
:Surveiller les équipements;
note right: Agent de service en session
:Détecter une anomalie / une panne;
:Déclarer la panne;

|#E5E8E8|Système|
:Enregistrer la panne;

|#FCF3CF|Chef de quart|
:Consulter la panne déclarée;
if (Panne valide ?) then (oui)
  :Valider la panne;

  |#E5E8E8|Système|
  :Créer une alerte;

  |#FCF3CF|Chef de quart|
  :Envoyer l'alerte au technicien;
  |#D4EFDF|Technicien|
  :Recevoir l'alerte;
  :Analyser la panne;

  while (Le technicien réalise-t-il une intervention ?) is (non)
    |#E5E8E8|Système|
    :Alerter le chef de quart;
    |#FCF3CF|Chef de quart|
    :Affecter un autre technicien;
    :Envoyer l'alerte au technicien;
    |#D4EFDF|Technicien|
    :Recevoir l'alerte;
    :Analyser la panne;
  endwhile (oui)

  |#D4EFDF|Technicien|
  repeat
    :Réaliser une intervention;
  repeat while (La panne est-elle résolue ?) is (non) not (oui)
  :Fermer la panne;
  :Mettre à jour l'état de l'équipement;

else (non)
  |#FCF3CF|Chef de quart|
  :Rejeter la panne;
endif

stop
@enduml