@startuml UC_ChefDeQuart
left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam usecase {
  BackgroundColor #EAF2F8
  BorderColor #2471A3
}
title Cas d'utilisation — Chef de quart

actor "Agent de service" as Agent
actor "Chef de quart" as CQ
CQ --|> Agent

note as N1
  Héritage : le chef de quart **est** un agent de service.
  Il possède donc tous les cas d'utilisation de l'agent
  (détaillés dans le diagramme « Agent de service »),
  en plus de ses propres cas ci-dessous.
end note

rectangle version0 {
  usecase "consulter les événements en cours"       as UC1
  usecase "gérer le tableau de service"             as UC2
  usecase "ajouter des instructions / consignes"    as UC3
  usecase "envoyer une alerte au technicien"        as UC4
  usecase "valider les comptes rendus"              as UC5
  usecase "générer un rapport périodique"           as UC6
  usecase "valider les demandes de maintenance"     as UC7
  usecase "consulter les remarques et instructions\ndu chef de service" as UC8
  usecase "s'authentifier"                          as AUTH

  CQ -- UC1
  CQ -- UC2
  CQ -- UC3
  CQ -- UC4
  CQ -- UC5
  CQ -- UC6
  CQ -- UC7
  CQ -- UC8

  UC1 ..> AUTH : <<include>>
  UC2 ..> AUTH : <<include>>
  UC3 ..> AUTH : <<include>>
  UC4 ..> AUTH : <<include>>
  UC5 ..> AUTH : <<include>>
  UC6 ..> AUTH : <<include>>
  UC7 ..> AUTH : <<include>>
  UC8 ..> AUTH : <<include>>
}
@enduml